{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "description": "OpenClaw Azure deployment template (No Feishu Version)."
  },
  "parameters": {
    "vmName": {
      "type": "string",
      "minLength": 3,
      "maxLength": 64,
      "metadata": {
        "description": "Name of the OpenClaw VM."
      }
    },
    "adminUsername": {
      "type": "string",
      "defaultValue": "azureuser",
      "minLength": 1,
      "maxLength": 32,
      "metadata": {
        "description": "Linux administrator username for SSH access."
      }
    },
    "sshPublicKey": {
      "type": "string",
      "metadata": {
        "description": "SSH public key used to sign in to the VM."
      }
    },
    "vmSize": {
      "type": "string",
      "defaultValue": "Standard_B2as_v2",
      "metadata": {
        "description": "VM size for the personal deployment."
      }
    },
    "dataDiskSizeGb": {
      "type": "int",
      "defaultValue": 32,
      "minValue": 32,
      "maxValue": 1024,
      "metadata": {
        "description": "Managed data disk size in GiB for /data."
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "southeastasia",
      "metadata": {
        "description": "Region used for Azure resources."
      }
    },
    "hostname": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Optional custom hostname."
      }
    },
    "azureOpenAiAuthMode": {
      "type": "string",
      "defaultValue": "none",
      "allowedValues": [
        "none",
        "key",
        "managedIdentity"
      ],
      "metadata": {
        "description": "Authentication mode for Azure OpenAI."
      }
    },
    "azureOpenAiEndpoint": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Optional Azure OpenAI endpoint."
      }
    },
    "azureOpenAiDeployment": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Optional Azure OpenAI deployment name."
      }
    },
    "azureOpenAiApiKey": {
      "type": "secureString",
      "defaultValue": "",
      "metadata": {
        "description": "Optional API key for the Azure OpenAI resource."
      }
    },
    "azureOpenAiResourceGroup": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Optional. Resource group of the Azure OpenAI resource."
      }
    },
    "msteamsAppId": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Optional Microsoft Teams Bot App ID."
      }
    },
    "msteamsAppPassword": {
      "type": "secureString",
      "defaultValue": "",
      "metadata": {
        "description": "Optional Microsoft Teams Bot App Password."
      }
    }
  },
  "variables": {
    "vnetName": "[format('{0}-vnet', parameters('vmName'))]",
    "subnetName": "default",
    "nsgName": "[format('{0}-nsg', parameters('vmName'))]",
    "publicIpName": "[format('{0}-pip', parameters('vmName'))]",
    "nicName": "[format('{0}-nic', parameters('vmName'))]",
    "dataDiskName": "[format('{0}-data', parameters('vmName'))]",
    "dnsLabel": "[take(toLower(replace(concat(parameters('vmName'), '-', uniqueString(resourceGroup().id)), '_', '-')), 63)]",
    "openclawPort": 18789,
    "deploymentLocation": "[if(empty(parameters('location')), resourceGroup().location, parameters('location'))]",
    "isAzureChinaCloud": "[equals(environment().name, 'AzureChinaCloud')]",
    "publicDnsSuffix": "[if(variables('isAzureChinaCloud'), 'cloudapp.chinacloudapi.cn', 'cloudapp.azure.com')]",
    "publicFqdn": "[format('{0}.{1}.{2}', variables('dnsLabel'), variables('deploymentLocation'), variables('publicDnsSuffix'))]",
    "publicOrigin": "[format('https://{0}', variables('publicFqdn'))]",
    "hostnameOrigin": "[if(empty(parameters('hostname')), '', format('https://{0}', parameters('hostname')))]",
    "publicControlUrl": "[if(empty(parameters('hostname')), format('https://{0}/', variables('publicFqdn')), format('https://{0}/', parameters('hostname')))]",
    "msteamsWebhookPath": "/api/messages",
    "msteamsPort": 3978,
    "msteamsWebhookUrl": "[if(empty(parameters('hostname')), format('https://{0}{1}', variables('publicFqdn'), variables('msteamsWebhookPath')), format('https://{0}{1}', parameters('hostname'), variables('msteamsWebhookPath')))]",
    "allowedOriginsJson": "[if(empty(parameters('hostname')), concat('[\"', variables('publicOrigin'), '\"]'), concat('[\"', variables('publicOrigin'), '\",\"', variables('hostnameOrigin'), '\"]'))]",
    "azureOpenAiEffectiveAuthMode": "[if(and(not(empty(parameters('azureOpenAiAuthMode'))), not(equals(parameters('azureOpenAiAuthMode'), 'none'))), parameters('azureOpenAiAuthMode'), if(and(not(empty(parameters('azureOpenAiEndpoint'))), not(empty(parameters('azureOpenAiDeployment'))), not(empty(parameters('azureOpenAiApiKey')))), 'key', ''))]",
    "azureOpenAiValidationMode": "[if(empty(variables('azureOpenAiEffectiveAuthMode')), if(and(empty(parameters('azureOpenAiEndpoint')), empty(parameters('azureOpenAiDeployment')), empty(parameters('azureOpenAiApiKey'))), 'disabled', 'enabled'), 'enabled')]",
    "isManagedIdentityAuth": "[equals(variables('azureOpenAiEffectiveAuthMode'), 'managedIdentity')]",
    "azureOpenAiResourceName": "[if(empty(parameters('azureOpenAiEndpoint')), '', first(split(last(split(parameters('azureOpenAiEndpoint'), '//')), '.')))]",
    "resolvedAzureOpenAiResourceGroup": "[if(empty(parameters('azureOpenAiResourceGroup')), resourceGroup().name, parameters('azureOpenAiResourceGroup'))]",
    "cognitiveServicesOpenAiUserRoleId": "5e0bd9bd-7b93-4f28-af87-19fc36ad61bd",
    "roleAssignmentName": "[guid(resourceId('Microsoft.Compute/virtualMachines', parameters('vmName')), variables('cognitiveServicesOpenAiUserRoleId'), variables('azureOpenAiResourceName'))]",
    "msteamsTenantId": "[subscription().tenantId]",
    "msteamsValidationMode": "[if(and(empty(parameters('msteamsAppId')), empty(parameters('msteamsAppPassword'))), 'disabled', 'enabled')]",
    "hasMsTeamsConfig": "[equals(variables('msteamsValidationMode'), 'enabled')]",
    "botServiceName": "[format('{0}-bot-{1}', take(parameters('vmName'), 51), substring(uniqueString(resourceGroup().id, parameters('msteamsAppId')), 0, 8))]",
    "caddySiteAddresses": "[if(empty(parameters('hostname')), variables('publicFqdn'), format('{0}, {1}', variables('publicFqdn'), parameters('hostname')))]",
    "caddyConfig": "[concat(variables('caddySiteAddresses'), ' {\n', '    encode zstd gzip\n', '    handle ', variables('msteamsWebhookPath'), ' {\n', '        reverse_proxy 127.0.0.1:', string(variables('msteamsPort')), '\n', '    }\n', '    reverse_proxy 127.0.0.1:', string(variables('openclawPort')), '\n', '}\n')]",
    "caddyConfigBase64": "[base64(variables('caddyConfig'))]",
    "bootstrapScript": "[format('#!/usr/bin/env bash\nset -eux\nexport DEBIAN_FRONTEND=noninteractive\napt-get update\napt-get install -y ca-certificates curl git gnupg caddy build-essential procps file\ninstall -d -o root -g {5} -m 0750 /etc/openclaw\ncat > /etc/sudoers.d/90-{5}-nopasswd <<EOF\n{5} ALL=(ALL:ALL) NOPASSWD:ALL\nEOF\nTOKEN=$(head -c 24 /dev/urandom | base64 | tr -d ''\\n'' | tr ''/+'' ''_-'')\ncat > /etc/openclaw/openclaw.env <<EOF\nHOME=/home/{5}\nOPENCLAW_STATE_DIR=/home/{5}/.openclaw\nOPENCLAW_CONFIG_PATH=/home/{5}/.openclaw/openclaw.json\nOPENCLAW_GATEWAY_PORT={0}\nOPENCLAW_GATEWAY_TOKEN=$TOKEN\nOPENCLAW_PUBLIC_URL={4}\nPATH=/home/{5}/.openclaw/tools/node/bin:/home/{5}/.openclaw/bin:/usr/local/bin:/usr/bin:/bin\nEOF\nchown root:{5} /etc/openclaw/openclaw.env\nchmod 640 /etc/openclaw/openclaw.env\nexport HOME=/root\ngit config --global --add url.\"https://github.com/\".insteadOf ssh://git@github.com/\ngit config --global --add url.\"https://github.com/\".insteadOf git@github.com:\nOPENCLAW_AZURE_OPENAI_API_KEY=''{1}''\nOPENCLAW_AZURE_OPENAI_AUTH_MODE=''{2}''\nOPENCLAW_MSTEAMS_APP_ID=''{6}''\nOPENCLAW_MSTEAMS_APP_PASSWORD=''{7}''\nOPENCLAW_MSTEAMS_TENANT_ID=''{8}''\nOPENCLAW_AZURE_OPENAI_ENDPOINT=''{9}''\nOPENCLAW_AZURE_OPENAI_DEPLOYMENT=''{10}''\nOPENCLAW_ALLOWED_ORIGINS_JSON=''{11}''\nsudo -u {5} env HOME=\"/home/{5}\" bash -c \"curl -fsSL https://openclaw.ai/install-cli.sh | bash -s -- --no-onboard\"\n# ... (後續原始碼省略，確保上述 `export HOME=/root` 有加進去即可)\n', string(variables('openclawPort')), parameters('azureOpenAiApiKey'), parameters('azureOpenAiAuthMode'), variables('caddyConfigBase64'), variables('publicControlUrl'), parameters('adminUsername'), parameters('msteamsAppId'), parameters('msteamsAppPassword'), variables('msteamsTenantId'), parameters('azureOpenAiEndpoint'), parameters('azureOpenAiDeployment'), variables('allowedOriginsJson'))]",
    "bootstrapScriptBase64": "[base64(variables('bootstrapScript'))]",
    "cloudInit": "[concat('#cloud-config\n')]"
  },
  "resources": [
    {
      "type": "Microsoft.Network/networkSecurityGroups",
      "apiVersion": "2024-05-01",
      "name": "[variables('nsgName')]",
      "location": "[variables('deploymentLocation')]",
      "properties": {
        "securityRules": [
          {
            "name": "allow-ssh",
            "properties": { "priority": 1000, "direction": "Inbound", "access": "Allow", "protocol": "Tcp", "sourcePortRange": "*", "destinationPortRange": "22", "sourceAddressPrefix": "*", "destinationAddressPrefix": "*" }
          },
          {
            "name": "allow-http",
            "properties": { "priority": 1010, "direction": "Inbound", "access": "Allow", "protocol": "Tcp", "sourcePortRange": "*", "destinationPortRange": "80", "sourceAddressPrefix": "*", "destinationAddressPrefix": "*" }
          },
          {
            "name": "allow-https",
            "properties": { "priority": 1020, "direction": "Inbound", "access": "Allow", "protocol": "Tcp", "sourcePortRange": "*", "destinationPortRange": "443", "sourceAddressPrefix": "*", "destinationAddressPrefix": "*" }
          }
        ]
      }
    },
    {
      "type": "Microsoft.Network/publicIPAddresses",
      "apiVersion": "2024-05-01",
      "name": "[variables('publicIpName')]",
      "location": "[variables('deploymentLocation')]",
      "sku": { "name": "Standard" },
      "properties": { "publicIPAllocationMethod": "Static", "dnsSettings": { "domainNameLabel": "[variables('dnsLabel')]" } }
    },
    {
      "type": "Microsoft.Network/virtualNetworks",
      "apiVersion": "2024-05-01",
      "name": "[variables('vnetName')]",
      "location": "[variables('deploymentLocation')]",
      "properties": {
        "addressSpace": { "addressPrefixes": ["10.40.0.0/16"] },
        "subnets": [{ "name": "default", "properties": { "addressPrefix": "10.40.0.0/24", "networkSecurityGroup": { "id": "[resourceId('Microsoft.Network/networkSecurityGroups', variables('nsgName'))]" } } }]
      },
      "dependsOn": ["[resourceId('Microsoft.Network/networkSecurityGroups', variables('nsgName'))]"]
    },
    {
      "type": "Microsoft.Network/networkInterfaces",
      "apiVersion": "2024-05-01",
      "name": "[variables('nicName')]",
      "location": "[variables('deploymentLocation')]",
      "properties": {
        "ipConfigurations": [{
          "name": "ipconfig1",
          "properties": {
            "subnet": { "id": "[resourceId('Microsoft.Network/virtualNetworks/subnets', variables('vnetName'), 'default')]" },
            "publicIPAddress": { "id": "[resourceId('Microsoft.Network/publicIPAddresses', variables('publicIpName'))]" }
          }
        }]
      },
      "dependsOn": ["[resourceId('Microsoft.Network/publicIPAddresses', variables('publicIpName'))]", "[resourceId('Microsoft.Network/virtualNetworks', variables('vnetName'))]"]
    },
    {
      "type": "Microsoft.Compute/disks",
      "apiVersion": "2024-03-02",
      "name": "[variables('dataDiskName')]",
      "location": "[variables('deploymentLocation')]",
      "properties": { "creationData": { "createOption": "Empty" }, "diskSizeGB": "[parameters('dataDiskSizeGb')]" }
    },
    {
      "type": "Microsoft.Compute/virtualMachines",
      "apiVersion": "2024-03-01",
      "name": "[parameters('vmName')]",
      "location": "[variables('deploymentLocation')]",
      "identity": { "type": "SystemAssigned" },
      "properties": {
        "hardwareProfile": { "vmSize": "[parameters('vmSize')]" },
        "osProfile": {
          "computerName": "[parameters('vmName')]",
          "adminUsername": "[parameters('adminUsername')]",
          "linuxConfiguration": {
            "disablePasswordAuthentication": true,
            "ssh": { "publicKeys": [{ "path": "[format('/home/{0}/.ssh/authorized_keys', parameters('adminUsername'))]", "keyData": "[parameters('sshPublicKey')]" }] }
          }
        },
        "storageProfile": {
          "imageReference": { "publisher": "Canonical", "offer": "ubuntu-24_04-lts", "sku": "server", "version": "latest" },
          "dataDisks": [{ "lun": 0, "createOption": "Attach", "managedDisk": { "id": "[resourceId('Microsoft.Compute/disks', variables('dataDiskName'))]" } }]
        },
        "networkProfile": { "networkInterfaces": [{ "id": "[resourceId('Microsoft.Network/networkInterfaces', variables('nicName'))]" }] }
      },
      "dependsOn": ["[resourceId('Microsoft.Compute/disks', variables('dataDiskName'))]", "[resourceId('Microsoft.Network/networkInterfaces', variables('nicName'))]"]
    },
    {
      "type": "Microsoft.BotService/botServices",
      "apiVersion": "2022-09-15",
      "name": "[variables('botServiceName')]",
      "location": "global",
      "kind": "azurebot",
      "properties": {
        "displayName": "[variables('botServiceName')]",
        "endpoint": "[variables('msteamsWebhookUrl')]",
        "msaAppId": "[parameters('msteamsAppId')]",
        "msaAppTenantId": "[variables('msteamsTenantId')]",
        "msaAppType": "SingleTenant"
      },
      "condition": "[variables('hasMsTeamsConfig')]"
    },
    {
      "type": "Microsoft.BotService/botServices/channels",
      "apiVersion": "2022-09-15",
      "name": "[format('{0}/{1}', variables('botServiceName'), 'MsTeamsChannel')]",
      "location": "global",
      "properties": { "channelName": "MsTeamsChannel" },
      "condition": "[variables('hasMsTeamsConfig')]",
      "dependsOn": ["[resourceId('Microsoft.BotService/botServices', variables('botServiceName'))]"]
    },
    {
      "type": "Microsoft.Compute/virtualMachines/extensions",
      "apiVersion": "2024-03-01",
      "name": "[format('{0}/openclaw-bootstrap', parameters('vmName'))]",
      "location": "[variables('deploymentLocation')]",
      "properties": {
        "publisher": "Microsoft.Azure.Extensions",
        "type": "CustomScript",
        "typeHandlerVersion": "2.1",
        "protectedSettings": { "script": "[variables('bootstrapScriptBase64')]" }
      },
      "dependsOn": ["[resourceId('Microsoft.Compute/virtualMachines', parameters('vmName'))]"]
    }
  ],
  "outputs": {
    "openclawPublicUrl": { "type": "string", "value": "[variables('publicControlUrl')]" },
    "teamsBotName": { "type": "string", "value": "[if(variables('hasMsTeamsConfig'), variables('botServiceName'), '')]" }
  }
}